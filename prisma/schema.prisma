generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(cuid())
  name              String
  phone             String           @unique
  email             String?          @unique
  role              String
  district          String?
  languages         String?
  passwordHash      String?
  createdAt         DateTime         @default(now())
  applications      Application[]    @relation("workerApplications")
  employerProfile   EmployerProfile?
  favoritesGiven    Favorite[]       @relation("employerFavorites")
  favoritesReceived Favorite[]       @relation("workerFavoritedBy")
  jobsPosted        Job[]            @relation("employerJobs")
  notifications     Notification[]   @relation("userNotifications")
  reviewsReceived   Review[]         @relation("reviewsReceived")
  reviewsWritten    Review[]         @relation("reviewsWritten")
  verifications     Verification[]
  workerProfile     WorkerProfile?
}

model EmployerProfile {
  id           String  @id @default(cuid())
  userId       String  @unique
  organization String?
  user         User    @relation(fields: [userId], references: [id])
}

model WorkerProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  category        String
  skills          String?
  experienceYears Int     @default(0)
  availability    String
  minMonthlyPay   Int?
  liveIn          Boolean @default(false)
  bio             String?
  photoUrl        String?
  rating          Float   @default(0)
  reviewCount     Int     @default(0)
  nationalId      String?
  passportNumber  String?
  passportUrl     String?
  user            User    @relation(fields: [userId], references: [id])
}

model Job {
  id           String        @id @default(cuid())
  employerId   String
  title        String
  category     String
  description  String
  budget       Int?
  district     String?
  status       String        @default("OPEN")
  createdAt    DateTime      @default(now())
  deadline     DateTime?
  applications Application[]
  employer     User          @relation("employerJobs", fields: [employerId], references: [id])

  @@index([employerId])
  @@index([category])
  @@index([deadline])
}

model Application {
  id        String   @id @default(cuid())
  jobId     String
  workerId  String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id])
  worker    User     @relation("workerApplications", fields: [workerId], references: [id])

  @@unique([jobId, workerId])
  @@index([workerId])
}

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  reviewee   User     @relation("reviewsReceived", fields: [revieweeId], references: [id])
  reviewer   User     @relation("reviewsWritten", fields: [reviewerId], references: [id])

  @@unique([reviewerId, revieweeId])
  @@index([revieweeId])
  @@index([reviewerId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation("userNotifications", fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
}

model Verification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  status    String    @default("PENDING")
  issuedAt  DateTime?
  expiresAt DateTime?
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Favorite {
  employerId String
  workerId   String
  createdAt  DateTime @default(now())
  employer   User     @relation("employerFavorites", fields: [employerId], references: [id])
  worker     User     @relation("workerFavoritedBy", fields: [workerId], references: [id])

  @@id([employerId, workerId])
  @@index([workerId])
}
