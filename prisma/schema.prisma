// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  phone        String    @unique
  email        String?   @unique
  role         String
  district     String?
  languages    String?   // comma-separated: "kinyarwanda,en,fr"
  passwordHash String?
  createdAt    DateTime  @default(now())

  employerProfile EmployerProfile?
  workerProfile   WorkerProfile?

  reviewsWritten  Review[]        @relation("reviewsWritten")
  reviewsReceived Review[]        @relation("reviewsReceived")
  verifications   Verification[]

  favoritesGiven  Favorite[]      @relation("employerFavorites")
  favoritesReceived Favorite[]    @relation("workerFavoritedBy")

  jobsPosted      Job[]           @relation("employerJobs")
  applications    Application[]   @relation("workerApplications")
}

model EmployerProfile {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id])
  organization String?
}

model WorkerProfile {
  id              String      @id @default(cuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id])
  category        String
  skills          String?
  experienceYears Int         @default(0)
  availability    String
  minMonthlyPay   Int?
  liveIn          Boolean     @default(false)
  bio             String?
  photoUrl        String?
  nationalId      String?
  passportNumber  String?
  passportUrl     String?
  rating          Float       @default(0)
  reviewCount     Int         @default(0)
}

model Job {
  id          String     @id @default(cuid())
  employerId  String
  employer    User       @relation("employerJobs", fields: [employerId], references: [id])
  title       String
  category    String
  description String
  budget      Int?
  district    String?
  status      String  @default("OPEN")
  createdAt   DateTime   @default(now())

  applications Application[]

  @@index([employerId])
  @@index([category])
}

model Application {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  workerId  String
  worker    User     @relation("workerApplications", fields: [workerId], references: [id])
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  @@unique([jobId, workerId])
  @@index([workerId])
}

model Review {
  id          String   @id @default(cuid())
  reviewerId  String
  reviewer    User     @relation("reviewsWritten", fields: [reviewerId], references: [id])
  revieweeId  String
  reviewee    User     @relation("reviewsReceived", fields: [revieweeId], references: [id])
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  @@index([revieweeId])
  @@index([reviewerId])
}

model Verification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  status    String   @default("PENDING")
  issuedAt  DateTime?
  expiresAt DateTime?

  @@index([userId])
}

model Favorite {
  employerId String
  employer   User   @relation("employerFavorites", fields: [employerId], references: [id])
  workerId   String
  worker     User   @relation("workerFavoritedBy", fields: [workerId], references: [id])
  createdAt  DateTime @default(now())

  @@id([employerId, workerId])
  @@index([workerId])
}
